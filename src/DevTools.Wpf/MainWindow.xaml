<Window x:Class="DevTools.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:DevTools.Wpf"
        xmlns:logging="clr-namespace:DevTools.Wpf.Infrastructure.Logging"
        mc:Ignorable="d"
        Title="DevTools WPF (Migration Preview)"
        Height="820"
        Width="1360"
        MinHeight="720"
        MinWidth="1120"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{DynamicResource SurfaceAltBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image x:Name="WindowIconImage" Width="20" Height="20" Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="DevTools WPF (Migration Preview)"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource WindowCaptionButtonStyle}"
                        Content="&#xE921;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="MinimizeButton_Click"/>

                <Button x:Name="MaximizeRestoreButton"
                        Grid.Column="2"
                        Style="{StaticResource WindowCaptionButtonStyle}"
                        Content="&#xE922;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="MaximizeRestoreButton_Click"/>

                <Button Grid.Column="3"
                        Style="{StaticResource WindowCloseButtonStyle}"
                        Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="CloseButton_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource SurfaceBrush}">
                    <TreeView x:Name="ToolNavigationTree"
                              Margin="8"
                              SelectedItemChanged="ToolNavigationTree_SelectedItemChanged">
                        <TreeViewItem Header="Tools" IsExpanded="True">
                            <TreeViewItem Header="Modbus" IsExpanded="True">
                                <TreeViewItem Header="Modbus RTU client"/>
                                <TreeViewItem Header="Modbus RTU Server"/>
                                <TreeViewItem Header="Modbus TCP client"/>
                                <TreeViewItem Header="Modbus TCP Server"/>
                                <TreeViewItem Header="Modbus RTU Serial Scanner"/>
                            </TreeViewItem>
                        </TreeViewItem>
                        <TreeViewItem Header="Settings"/>
                        <TreeViewItem Header="Help"/>
                    </TreeView>
                </Border>

                <GroupBox x:Name="WorkAreaGroup"
                          Grid.Column="2"
                          Grid.Row="0"
                          Header="Welcome"
                          Margin="0">
                    <ContentControl x:Name="WorkAreaContentHost"/>
                </GroupBox>

                <Expander x:Name="OutputConsoleExpander"
                          Grid.Column="2"
                          Grid.Row="2"
                          Header="Output Console"
                          IsExpanded="False"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          BorderThickness="1">
                    <Grid Height="150">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="OutputConsoleList"
                                 Grid.Row="0"
                                 Margin="6"
                                 Background="{DynamicResource AppBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontFamily="Courier New"
                                 FontSize="10"
                                 ItemsSource="{Binding Source={x:Static logging:OutputLogger.Instance}, Path=Logs}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="NoWrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="1" Margin="6,0,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="/" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="ConsoleInputBox"
                                     Grid.Column="1"
                                     MinWidth="0"
                                     Margin="0,0,6,0"
                                     VerticalContentAlignment="Center"
                                     KeyDown="ConsoleInputBox_KeyDown"/>
                            <Button Grid.Column="2"
                                    Content="Run"
                                    Margin="0,0,6,0"
                                    Click="RunConsoleButton_Click"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                            <Button Grid.Column="3"
                                    Content="Clear"
                                    Click="ClearOutputButton_Click"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Expander>
            </Grid>
        </Grid>
    </Border>
</Window>
